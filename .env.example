# ============================================================================
# Disbord environment template.
#
# Copy this file to `.env` at the project root and adjust as needed. The
# values below are dev-friendly defaults — safe to commit, NOT safe for
# production. Phase 6 will document production overrides.
#
# Both the API (apps/api) and Docker Compose (infra/docker-compose.yml) read
# variables from this file. The docker-compose stack also falls back to these
# same defaults internally, so an empty .env still works.
# ============================================================================

# ---------------------------------------------------------------------------
# Application — apps/api
# ---------------------------------------------------------------------------
# Runtime environment: development | production | test
NODE_ENV=development
# Fastify listen port for the API.
PORT=3001
# Fastify bind host. 0.0.0.0 listens on all interfaces (required inside Docker).
HOST=0.0.0.0
# Pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# Origin allowed by the @fastify/cors plugin. In dev, this is the Vite server.
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Postgres — infra/docker-compose.yml service `postgres`
# ---------------------------------------------------------------------------
POSTGRES_DB=disbord
POSTGRES_USER=disbord
POSTGRES_PASSWORD=disbord_dev
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis — infra/docker-compose.yml service `redis`
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage) — infra/docker-compose.yml service `minio`
# ---------------------------------------------------------------------------
# Root credentials for the MinIO console at http://localhost:9001
MINIO_ROOT_USER=disbord
MINIO_ROOT_PASSWORD=disbord_dev_minio
# S3 API port (used by the SDK).
MINIO_PORT=9000
# Web console port.
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------------------------------
# LiveKit — infra/docker-compose.yml service `livekit`
# ---------------------------------------------------------------------------
# HTTP / WebSocket signaling port.
LIVEKIT_HTTP_PORT=7880
# RTC TCP fallback port.
LIVEKIT_TCP_PORT=7881
# RTC UDP media port.
LIVEKIT_UDP_PORT=7882

# DEV-ONLY API key / secret. These match infra/livekit/livekit.yaml. DO NOT
# use these values in production — Phase 6 provisions real credentials.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=disbord_dev_livekit_secret_32chars_minimum_xxxxxxxxxxx

# ---------------------------------------------------------------------------
# Mailhog (dev SMTP catcher) — infra/docker-compose.yml service `mailhog`
# ---------------------------------------------------------------------------
# SMTP submission port (your API points here in dev).
MAILHOG_SMTP_PORT=1025
# Web UI at http://localhost:8025
MAILHOG_UI_PORT=8025
